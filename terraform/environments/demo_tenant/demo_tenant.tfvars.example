# Copy this file to a local .tfvars file (do not commit secrets)
# Example: demo_tenant.tfvars

tenant_id           = "demo-customer-001"
tenant_display_name = "Demo Customer 001"

aws_region  = "eu-west-1"
aws_profile = "PowerUser-IAMFullAccess-760659115776"

project_name = "secamo"
environment  = "demo_tenant"

soc_analyst_email = "soc.analyst@contoso.com"

# TenantConfig behavior
iam_provider            = "microsoft_graph"
edr_provider            = "microsoft_defender"
ticketing_provider      = "jira"
notification_provider   = "teams"
threat_intel_providers  = "virustotal,abuseipdb"
sla_tier                = "standard"
hitl_timeout_hours      = 4
escalation_enabled      = true
auto_isolate_on_timeout = false
max_activity_attempts   = 3
threat_intel_enabled    = true
evidence_bundle_enabled = true
auto_ticket_creation    = true
misp_sharing_enabled    = false

polling_providers   = "microsoft_defender:defender_alerts:graph:300,jira:tickets:ticketing:300"
graph_subscriptions = "security/alerts_v2:created+updated:false:24,auditLogs/signIns:created+updated:false:24"

# Graph / Defender (required by shared activities tenant secret model)
graph_client_id       = "00000000-0000-0000-0000-000000000000"
graph_client_secret   = "replace-me"
graph_tenant_azure_id = "11111111-1111-1111-1111-111111111111"

# Ticketing
ticketing_jira_base_url        = "https://your-tenant.atlassian.net"
ticketing_jira_email           = "automation@contoso.com"
ticketing_jira_api_token       = "replace-me"
ticketing_project_key          = "SOC"
ticketing_project_type         = "standard"
ticketing_jsm_service_desk_id  = ""

# ChatOps / Threat Intel / HiTL
chatops_teams_webhook_url      = "https://outlook.office.com/webhook/..."
threatintel_virustotal_api_key = "replace-me"
threatintel_abuseipdb_api_key  = "replace-me"
hitl_jira_webhook_secret       = "replace-me"
webhooks_jira_secret           = "replace-me"
hitl_endpoint_base_url         = "https://your-shared-api-id.execute-api.eu-west-1.amazonaws.com/api/v1/hitl/respond"

# Azure provider and resources
azure_subscription_id              = "22222222-2222-2222-2222-222222222222"
azure_tenant_id                    = "11111111-1111-1111-1111-111111111111"
azure_client_id                    = ""
azure_client_secret                = ""
azure_skip_provider_registration   = false

azure_location            = "westeurope"
azure_resource_group_name = "rg-secamo-demo-customer-001"
azure_vnet_cidr           = "10.220.0.0/16"
azure_subnet_cidr         = "10.220.10.0/24"

azure_vm_name             = "secamo-demo-win-01"
azure_vm_size             = "Standard_B2s"
azure_vm_admin_username   = "secamoadmin"
azure_vm_admin_password   = "ReplaceWithStrongPassword!123"
azure_admin_allowed_cidr  = "203.0.113.10/32"
azure_public_ip_enabled   = true

defender_for_servers_subplan = "P1"

extra_tags = {
  Owner      = "secops"
  CostCenter = "demo"
}
