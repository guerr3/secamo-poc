# ── Secamo Worker Environment ─────────────────────────────────
# This file is injected on the EC2 at deploy time.
# Copy this to .env and fill in your values.
# ──────────────────────────────────────────────────────────────

# Temporal (self-hosted: no API key needed)
TEMPORAL_ADDRESS=temporal:7233
TEMPORAL_NAMESPACE=default
# TEMPORAL_API_KEY=

# Microsoft Graph — Sandbox tenant 1
GRAPH_TENANT1_ID=
GRAPH_CLIENT1_ID=
GRAPH_SECRET1_VALUE=
GRAPH_SECRET1_ID=
